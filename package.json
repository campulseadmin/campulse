{
  "name": "campulse",
  "version": "0.1.0",
  "private": true,
  "description": "CamPulse — the pulse of your campus. Multi-tenant campus super-app (SRM = campus 1).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-events": "tsx prisma/seed-events.ts",
    "db:seed-posts": "tsx prisma/seed-posts.ts",
    "db:seed-all": "tsx prisma/seed.ts && tsx prisma/seed-posts.ts && tsx prisma/seed-events.ts",
    "vercel-build": "prisma generate && prisma db push --skip-generate && tsx prisma/seed.ts && tsx prisma/seed-events.ts && next build",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "bcryptjs": "^2.4.3",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "nodemailer": "^7.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "prisma": "^5.19.1",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
