# ── CamPulse environment ──────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN REAL VALUES. .env IS GIT-IGNORED.
# NEVER commit a real .env — it contains the SMTP app password + secrets.

# Database
# LOCAL (SQLite):  DATABASE_URL="file:./dev.db"
# VERCEL/PROD (Postgres): set by Vercel Postgres / Neon / Supabase as DATABASE_URL.
#   The schema uses provider = "postgresql". For local SQLite dev, change the
#   provider in prisma/schema.prisma back to "sqlite".
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"   # on Vercel this is set automatically to the deploy URL
NEXTAUTH_SECRET="replace-with-a-long-random-string"   # REQUIRED in prod; generate: openssl rand -base64 32

# Email / OTP delivery
# EMAIL_MODE=console  -> prints OTP codes to the server terminal (no email sent)
# EMAIL_MODE=smtp    -> sends real OTP emails via SMTP (needs the fields below)
EMAIL_MODE="console"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-campulse-app@gmail.com"
SMTP_PASS="your-16-char-gmail-app-password"
EMAIL_FROM="CamPulse <your-campulse-app@gmail.com>"

# ── Admin bootstrap (used by `prisma db seed` on a FRESH database) ──
# Creates one ADMIN account if no user with ADMIN_EMAIL exists. Idempotent.
# CHANGE THESE before a real deploy — the defaults are dev-only.
ADMIN_EMAIL="am8269@srmist.edu.in"
ADMIN_PASSWORD="changeme123"
ADMIN_HANDLE="campulseadmin"

# ── Event ingestion from campus-owned social handles (CamPulse IG + Reddit) ──
# All OPTIONAL. If missing, the Events feed uses only seeded/admin events.
# No 403 ever reaches a parser — lib/sources.ts failsafe-returns [] per source.

# Reddit: register a "script"/web app at https://www.reddit.com/prefs/apps
# (free, no review). Use the app's client id + secret for app-only OAuth2.
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_SUBREDDIT="SRMCampusPulse"

# Instagram: Business/Creator IG account linked to a FB Page + a Meta app.
# Generate a long-lived Page access token; fetch media via Graph API.
IG_USER_ID=""
IG_ACCESS_TOKEN=""
IG_HANDLE="@campulse.srm"
