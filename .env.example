# ── CamPulse environment ──────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN REAL VALUES. .env IS GIT-IGNORED.
# NEVER commit a real .env — it contains the SMTP app password + secrets.

# Database (SQLite for local; swap to postgres in prod)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Email / OTP delivery
# EMAIL_MODE=console  -> prints OTP codes to the server terminal (no email sent)
# EMAIL_MODE=smtp    -> sends real OTP emails via SMTP (needs the fields below)
EMAIL_MODE="console"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-campulse-app@gmail.com"
SMTP_PASS="your-16-char-gmail-app-password"
EMAIL_FROM="CamPulse <your-campulse-app@gmail.com>"
