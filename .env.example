# ── CamPulse environment ──────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN REAL VALUES. .env IS GIT-IGNORED.
# NEVER commit a real .env — it contains SMTP passwords + secrets.
#
# Sections: Database | Auth | Email (OTP) | Admin bootstrap | Reddit Agent | Instagram Agent | Cron | App

# =======================================================================
# Database
# =======================================================================
# LOCAL (SQLite):  DATABASE_URL="file:./dev.db"
# VERCEL/PROD (Postgres): set by Vercel Postgres / Neon / Supabase as DATABASE_URL.
#   The schema uses provider = "postgresql". For local SQLite dev, change the
#   provider in prisma/schema.prisma back to "sqlite".
DATABASE_URL="file:./dev.db"

# =======================================================================
# Auth (NextAuth.js)
# =======================================================================
# On Vercel this is set automatically to the deploy URL.
NEXTAUTH_URL="http://localhost:3000"

# REQUIRED in production — generate with: openssl rand -base64 32
# Used for: JWT session encryption, HMAC signing of OTP grants/codes.
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# =======================================================================
# Email / OTP delivery
# =======================================================================
# EMAIL_MODE=console  -> prints OTP codes to the server terminal (no email sent)
# EMAIL_MODE=smtp     -> sends real OTP emails via SMTP (needs fields below)
EMAIL_MODE="console"

# SMTP settings (required when EMAIL_MODE=smtp)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-campulse-app@gmail.com"
SMTP_PASS="your-16-char-gmail-app-password"
EMAIL_FROM="CamPulse <your-campulse-app@gmail.com>"

# =======================================================================
# Admin bootstrap (used by `prisma db seed` on a FRESH database)
# =======================================================================
# Creates one ADMIN account if no user with ADMIN_EMAIL exists. Idempotent.
# CHANGE THESE before any real deploy — the defaults are dev-only.
ADMIN_EMAIL="am8269@srmist.edu.in"
ADMIN_PASSWORD="changeme123"
ADMIN_HANDLE="campulseadmin"

# =======================================================================
# Reddit Agent (Event Discovery from campus-owned subreddit)
# Reads the PUBLIC RSS feed (no Reddit app/OAuth required):
#   https://www.reddit.com/r/<REDDIT_SUBREDDIT>/new.rss
# ToS-compliant; just set the subreddit name below.
# (Reddit app credentials are only needed if you later switch to authenticated
#  .json polling — the current agent does NOT use them.)
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_SUBREDDIT="SRMIST"

# =======================================================================
# Instagram Agent (Event Discovery from campus-owned Instagram)
# =======================================================================
# Requires: Business/Creator IG account linked to a FB Page + a Meta App.
# Generate a long-lived Page access token; fetch media via Graph API.
IG_USER_ID=""
IG_ACCESS_TOKEN=""
IG_HANDLE="@campulse.srm"

# =======================================================================
# Cron (protects /api/cron/ingest endpoint)
# =======================================================================
# A shared secret passed via the `x-cron-secret` header by external schedulers:
#   - Vercel Cron
#   - GitHub Actions (scheduled workflow with curl + header)
#   - Windows Task Scheduler / any external cron
# Generate with: openssl rand -hex 16
CRON_SECRET=""

# =======================================================================
# App (misc)
# =======================================================================
# Node env (set automatically by Next.js: development / production / test)
# NODE_ENV="development"