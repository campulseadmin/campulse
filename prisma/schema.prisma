// CamPulse — multi-tenant campus super-app (SRM = campusId 1)
// LOCAL DEV uses SQLite (runs with zero setup: `npm run dev`).
// For Vercel deploy, swap `provider` to "postgresql" and set DATABASE_URL to a
// hosted Postgres (Vercel Postgres / Neon / Supabase). Schema is otherwise
// identical across both engines. See DEPLOY.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Tenancy ──────────────────────────────────────────────
model Campus {
  id          Int      @id @default(autoincrement())
  name        String // "SRM Institute of Science and Technology"
  shortName   String // "SRM"
  slug        String   @unique // "srm"
  emailDomain String // "srmist.edu.in" — gate signups to this domain
  createdAt   DateTime @default(now())

  users         User[]
  communities   Community[]
  posts         Post[]
  events        Event[]
  adminRequests AdminRequest[]
  Resource      Resource[]
}

// ── Users ────────────────────────────────────────────────
// Roles stored as string (STUDENT | MODERATOR | ADMIN). String for SQLite portability.

model User {
  id                String    @id @default(cuid())
  campusId          Int
  campus            Campus    @relation(fields: [campusId], references: [id])
  email             String    @unique // srm email, verified
  passwordHash      String? // bcrypt hash; set at signup (email+password auth)
  emailVerified     DateTime?
  username          String?   @unique // @handle, chosen at onboarding
  displayName       String?
  avatarUrl         String?
  bio               String?
  role              String    @default("STUDENT") // STUDENT | MODERATOR | ADMIN
  dept              String? // CSE, ECE...
  batch             String? // 2023-2027
  isBanned          Boolean   @default(false)
  bannedUntil       DateTime?
  usernameChangedAt DateTime? // last @handle change (14-day cooldown)
  createdAt         DateTime  @default(now())

  posts         Post[]
  comments      Comment[]
  likes         Like[]
  commentLikes  CommentLike[]
  rsvps         Rsvp[]
  bookmarks     Bookmark[]
  memberships   Membership[]
  reportsFiled  Report[]      @relation("Reporter")
  eventsCreated Event[]       @relation("EventCreator")

  // Social graph + moderation relations.
  following            Follow[]             @relation("Follower")
  followers            Follow[]             @relation("Following")
  mutes                Mute[]
  blocksAsBlocker      Block[]              @relation("Blocker")
  blocksAsBlocked      Block[]              @relation("Blocked")
  reposts              Repost[]
  bookmarkCollections  BookmarkCollection[]
  notInterested        NotInterested[]
  hiddenPosts          HiddenPost[]
  notifications        Notification[]       @relation("NotifUser")
  notificationsAsActor Notification[]       @relation("NotifActor")

  // Admin-approval requests this user has filed (they want to become an admin).
  adminRequests AdminRequest[] @relation("Requester")
  // Admin-approval requests this user has reviewed (as an admin).
  reviews       AdminRequest[] @relation("Reviewer")

  // Study Hub: resources this user uploaded / approved.
  uploadedResources Resource[] @relation("ResourceUploader")
  approvedResources Resource[] @relation("ResourceApprover")

  @@unique([campusId, username])
  @@index([campusId])
}

// One-time OTP login grant (minted after email code is verified; exchanged
// for a session via the credentials provider, then deleted).
model OtpGrant {
  email     String   @id
  grantHash String
  expiresAt DateTime

  @@index([email])
}

// OTP email verification codes
model OtpCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String // hashed 6-digit code
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ── Communities ──────────────────────────────────────────
// Community kind stored as string: DEPARTMENT | SUBJECT | INTEREST | OFFICIAL

model Community {
  id          String   @id @default(cuid())
  campusId    Int
  campus      Campus   @relation(fields: [campusId], references: [id])
  name        String
  slug        String
  description String?
  kind        String   @default("INTEREST") // DEPARTMENT | SUBJECT | INTEREST | OFFICIAL
  createdAt   DateTime @default(now())

  posts       Post[]
  memberships Membership[]

  @@unique([campusId, slug])
  @@index([campusId])
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  joinedAt    DateTime  @default(now())

  @@unique([userId, communityId])
}

// ── Feed ─────────────────────────────────────────────────
model Post {
  id          String     @id @default(cuid())
  campusId    Int
  campus      Campus     @relation(fields: [campusId], references: [id])
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id])
  body        String
  imageUrl    String?
  quotedId    String? // original post when this is a quote-post
  quoted      Post?      @relation("Quoted", fields: [quotedId], references: [id])
  isRemoved   Boolean    @default(false)
  editedAt    DateTime? // set when the author edits within the grace window
  createdAt   DateTime   @default(now())

  comments      Comment[]
  likes         Like[]
  reports       Report[]
  bookmarks     Bookmark[]
  reposts       Repost[]
  quotedBy      Post[]          @relation("Quoted")
  notInterested NotInterested[]
  hiddenBy      HiddenPost[]
  notifications Notification[]  @relation("NotifPost")
  pref          PostPref?

  @@index([campusId, createdAt])
  @@index([communityId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id])
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  parentId  String? // for nested replies (one level)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  body      String
  isRemoved Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  likes CommentLike[]

  @@index([postId])
  @@index([parentId])
}

// Like on a comment (separate from post Likes).
model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
}

// Saved posts (bookmarks).
model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

// ── Social graph & moderation ──────────────────────────
// Follows a user (one-directional, like Twitter).
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// Mute without blocking: user, hashtag (#tag), or topic (free-text keyword).
model Mute {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  kind      String   @default("USER") // USER | HASHTAG | TOPIC
  value     String // target userId (USER) or lowercased tag/topic
  createdAt DateTime @default(now())

  @@unique([userId, kind, value])
  @@index([userId])
}

// Hard block: neither side sees the other's posts in feeds.
model Block {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id])
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// Per-post author preferences (pin, comments off).
model PostPref {
  postId      String  @id
  post        Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  pinned      Boolean @default(false)
  commentsOff Boolean @default(false)
}

// Repost (share a post to your own timeline). kind REPOST | QUOTE.
// For QUOTE, the new Post body carries the commentary and `quotedId` links back.
model Repost {
  id        String   @id @default(cuid())
  postId    String // the (quote) post the user created
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  sourceId  String // the original post being reposted/quoted
  kind      String   @default("REPOST") // REPOST | QUOTE
  createdAt DateTime @default(now())

  @@unique([userId, sourceId, kind])
  @@index([sourceId])
  @@index([userId])
}

// Bookmark collections (folders) — every user has an implicit "all" via Bookmark.
model BookmarkCollection {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String // "Placement Prep", "Notes", "Events", "Funny"
  createdAt DateTime @default(now())

  bookmarks Bookmark[]

  @@unique([userId, name])
  @@index([userId])
}

// Bookmark now optionally lives in a collection.
model Bookmark {
  id           String              @id @default(cuid())
  postId       String
  post         Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId       String
  user         User                @relation(fields: [userId], references: [id])
  collectionId String?
  collection   BookmarkCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  createdAt    DateTime            @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

// Feed personalization signals.
// NotInterested: "show me fewer like this" — feeds future recommendations.
// Hidden: post removed from this user's view (soft, per-user).
model NotInterested {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
}

model HiddenPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
}

// Notifications: like / comment / follow / repost / mention.
model Notification {
  id        String   @id @default(cuid())
  userId    String // recipient
  user      User     @relation("NotifUser", fields: [userId], references: [id], onDelete: Cascade)
  type      String // LIKE | COMMENT | FOLLOW | REPOST | MENTION | ADMIN
  actorId   String? // who triggered it
  actor     User?    @relation("NotifActor", fields: [actorId], references: [id])
  postId    String? // related post (if any)
  post      Post?    @relation("NotifPost", fields: [postId], references: [id], onDelete: Cascade)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ── Events ───────────────────────────────────────────────
model Event {
  id          String    @id @default(cuid())
  campusId    Int
  campus      Campus    @relation(fields: [campusId], references: [id])
  creatorId   String
  creator     User      @relation("EventCreator", fields: [creatorId], references: [id])
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  isApproved  Boolean   @default(false)

  // Provenance — where the event came from. sourceType:
  //   ADMIN     — created by a campus admin in the admin panel
  //   SEED      — seeded curated content (known clubs, no external fetch)
  //   REDDIT    — ingested from the campus-owned subreddit
  //   INSTAGRAM — ingested from the campus-owned Instagram handle
  sourceType   String  @default("ADMIN")
  sourceHandle String? // e.g. "r/SRMCampusPulse", "@campulse.srm"
  sourceUrl    String? // permalink to the original post
  externalId   String? // platform post id (dedupe key)

  imageUrl String?

  createdAt DateTime @default(now())

  rsvps Rsvp[]

  // NOTE: no DB-level unique on (sourceType, externalId) — SQLite can't do a
  // partial unique, and (ADMIN, null) would collide across admin events.
  // Dedupe is enforced in code (lib/sources.ts) only for ingested posts that
  // carry a real externalId.
  @@index([campusId, startsAt])
}

model Rsvp {
  id      String   @id @default(cuid())
  eventId String
  event   Event    @relation(fields: [eventId], references: [id])
  userId  String
  user    User     @relation(fields: [userId], references: [id])
  goingAt DateTime @default(now())

  @@unique([eventId, userId])
}

// ── Admin access (approval-gated) ───────────────────────────
// A STUDENT requests admin access; an EXISTING ADMIN reviews & approves.
// Only approved requests flip the requester's role to ADMIN. Direct ADMIN
// assignment via the users endpoint is blocked — it must go through here.
// status: PENDING | APPROVED | REJECTED
model AdminRequest {
  id           String    @id @default(cuid())
  campusId     Int
  campus       Campus    @relation(fields: [campusId], references: [id])
  requesterId  String
  requester    User      @relation("Requester", fields: [requesterId], references: [id])
  reason       String? // optional justification from the requester
  status       String    @default("PENDING")
  reviewedById String? // admin who approved/rejected
  reviewedBy   User?     @relation("Reviewer", fields: [reviewedById], references: [id])
  createdAt    DateTime  @default(now())
  reviewedAt   DateTime?

  @@index([campusId, status])
  @@index([requesterId])
}

// ── Study Hub resources (Track B, Stage 1) ───────────────
// User-contributed study material (NOT scraped from other sites — see README).
// type: NOTE | PYQ | MATERIAL. Approved by an admin before it shows publicly,
// so the hub stays junk-free. driveUrl = a Google-Drive/share link the student
// owns (mirrors THE HELPER's custom-viewer model without rehosting files).
model Resource {
  id           String @id @default(cuid())
  campusId     Int
  campus       Campus @relation(fields: [campusId], references: [id])
  uploadedById String
  uploadedBy   User   @relation("ResourceUploader", fields: [uploadedById], references: [id])

  title       String
  type        String  @default("NOTE") // NOTE | PYQ | MATERIAL
  dept        String? // CSE, ECE, AIML...
  semester    Int? // 1..8
  driveUrl    String // student-owned share link
  description String?

  approved     Boolean @default(false)
  approvedById String?
  approvedBy   User?   @relation("ResourceApprover", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())

  @@index([campusId, approved])
  @@index([campusId, dept])
  @@index([campusId, type])
}

// ── Moderation ───────────────────────────────────────────
// Report status stored as string: OPEN | REVIEWED | ACTIONED | DISMISSED

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  postId     String?
  post       Post?    @relation(fields: [postId], references: [id])
  reason     String
  details    String?
  status     String   @default("OPEN") // OPEN | REVIEWED | ACTIONED | DISMISSED
  createdAt  DateTime @default(now())

  @@index([status])
}
