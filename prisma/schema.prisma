// CamPulse — multi-tenant campus super-app (SRM = campusId 1)
// LOCAL DEV uses SQLite (runs with zero setup: `npm run dev`).
// For Vercel deploy, swap `provider` to "postgresql" and set DATABASE_URL to a
// hosted Postgres (Vercel Postgres / Neon / Supabase). Schema is otherwise
// identical across both engines. See DEPLOY.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Tenancy ──────────────────────────────────────────────
model Campus {
  id          Int      @id @default(autoincrement())
  name        String // "SRM Institute of Science and Technology"
  shortName   String // "SRM"
  slug        String   @unique // "srm"
  emailDomain String // "srmist.edu.in" — gate signups to this domain
  createdAt   DateTime @default(now())

  users       User[]
  communities Community[]
  posts       Post[]
  events      Event[]
  adminRequests AdminRequest[]
}

// ── Users ────────────────────────────────────────────────
// Roles stored as string (STUDENT | MODERATOR | ADMIN). String for SQLite portability.

model User {
  id           String    @id @default(cuid())
  campusId     Int
  campus       Campus    @relation(fields: [campusId], references: [id])
  email        String    @unique // srm email, verified
  passwordHash String? // bcrypt hash; set at signup (email+password auth)
  emailVerified DateTime?
  username     String?   @unique // @handle, chosen at onboarding
  displayName  String?
  avatarUrl    String?
  bio          String?
  role         String    @default("STUDENT") // STUDENT | MODERATOR | ADMIN
  dept         String? // CSE, ECE...
  batch        String? // 2023-2027
  isBanned     Boolean   @default(false)
  bannedUntil  DateTime?
  usernameChangedAt DateTime? // last @handle change (14-day cooldown)
  createdAt    DateTime  @default(now())

  posts            Post[]
  comments         Comment[]
  likes            Like[]
  rsvps            Rsvp[]
  memberships      Membership[]
  reportsFiled     Report[]  @relation("Reporter")
  eventsCreated    Event[]   @relation("EventCreator")

  // Admin-approval requests this user has filed (they want to become an admin).
  adminRequests   AdminRequest[] @relation("Requester")
  // Admin-approval requests this user has reviewed (as an admin).
  reviews         AdminRequest[] @relation("Reviewer")

  @@index([campusId])
  @@unique([campusId, username])
}

// One-time OTP login grant (minted after email code is verified; exchanged
// for a session via the credentials provider, then deleted).
model OtpGrant {
  email     String   @id
  grantHash String
  expiresAt DateTime

  @@index([email])
}

// OTP email verification codes
model OtpCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String // hashed 6-digit code
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ── Communities ──────────────────────────────────────────
// Community kind stored as string: DEPARTMENT | SUBJECT | INTEREST | OFFICIAL

model Community {
  id          String        @id @default(cuid())
  campusId    Int
  campus      Campus        @relation(fields: [campusId], references: [id])
  name        String
  slug        String
  description String?
  kind        String        @default("INTEREST") // DEPARTMENT | SUBJECT | INTEREST | OFFICIAL
  createdAt   DateTime      @default(now())

  posts       Post[]
  memberships Membership[]

  @@unique([campusId, slug])
  @@index([campusId])
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  joinedAt    DateTime  @default(now())

  @@unique([userId, communityId])
}

// ── Feed ─────────────────────────────────────────────────
model Post {
  id          String     @id @default(cuid())
  campusId    Int
  campus      Campus     @relation(fields: [campusId], references: [id])
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id])
  body        String
  imageUrl    String?
  isRemoved   Boolean    @default(false)
  createdAt   DateTime   @default(now())

  comments Comment[]
  likes    Like[]
  reports  Report[]

  @@index([campusId, createdAt])
  @@index([communityId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  isRemoved Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([postId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

// ── Events ───────────────────────────────────────────────
model Event {
  id          String   @id @default(cuid())
  campusId    Int
  campus      Campus   @relation(fields: [campusId], references: [id])
  creatorId   String
  creator     User     @relation("EventCreator", fields: [creatorId], references: [id])
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  isApproved  Boolean  @default(false)

  // Provenance — where the event came from. sourceType:
  //   ADMIN     — created by a campus admin in the admin panel
  //   SEED      — seeded curated content (known clubs, no external fetch)
  //   REDDIT    — ingested from the campus-owned subreddit
  //   INSTAGRAM — ingested from the campus-owned Instagram handle
  sourceType  String   @default("ADMIN")
  sourceHandle String? // e.g. "r/SRMCampusPulse", "@campulse.srm"
  sourceUrl   String?  // permalink to the original post
  externalId  String?  // platform post id (dedupe key)

  imageUrl    String?

  createdAt   DateTime @default(now())

  rsvps Rsvp[]

  // NOTE: no DB-level unique on (sourceType, externalId) — SQLite can't do a
  // partial unique, and (ADMIN, null) would collide across admin events.
  // Dedupe is enforced in code (lib/sources.ts) only for ingested posts that
  // carry a real externalId.
  @@index([campusId, startsAt])
}

model Rsvp {
  id       String   @id @default(cuid())
  eventId  String
  event    Event    @relation(fields: [eventId], references: [id])
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  goingAt  DateTime @default(now())

  @@unique([eventId, userId])
}

// ── Admin access (approval-gated) ───────────────────────────
// A STUDENT requests admin access; an EXISTING ADMIN reviews & approves.
// Only approved requests flip the requester's role to ADMIN. Direct ADMIN
// assignment via the users endpoint is blocked — it must go through here.
// status: PENDING | APPROVED | REJECTED
model AdminRequest {
  id        String   @id @default(cuid())
  campusId  Int
  campus    Campus   @relation(fields: [campusId], references: [id])
  requesterId String
  requester User     @relation("Requester", fields: [requesterId], references: [id])
  reason    String?  // optional justification from the requester
  status    String   @default("PENDING")
  reviewedById   String? // admin who approved/rejected
  reviewedBy     User?   @relation("Reviewer", fields: [reviewedById], references: [id])
  createdAt DateTime @default(now())
  reviewedAt DateTime?

  @@index([campusId, status])
  @@index([requesterId])
}

// ── Moderation ───────────────────────────────────────────
// Report status stored as string: OPEN | REVIEWED | ACTIONED | DISMISSED

model Report {
  id         String       @id @default(cuid())
  reporterId String
  reporter   User         @relation("Reporter", fields: [reporterId], references: [id])
  postId     String?
  post       Post?        @relation(fields: [postId], references: [id])
  reason     String
  details    String?
  status     String       @default("OPEN") // OPEN | REVIEWED | ACTIONED | DISMISSED
  createdAt  DateTime     @default(now())

  @@index([status])
}
